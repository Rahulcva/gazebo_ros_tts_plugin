<launch>
  <!-- ═══════════════════════════════════════════
       gazebo_ros_tts — Demo Launch (Gazebo Classic)
       ═══════════════════════════════════════════ -->

  <!-- Arguments -->
  <arg name="tts_engine" default="espeak"/>
  <arg name="topic"      default="/robot/speak"/>
  <arg name="voice"      default="en"/>
  <arg name="rate"       default="150"/>
  <arg name="gui"        default="true"/>

  <!-- ── Gazebo empty world ───────────────────── -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="gui"     value="$(arg gui)"/>
    <arg name="paused"  value="false"/>
    <arg name="verbose" value="false"/>
  </include>

  <!-- ── Demo robot URDF (box robot) ─────────── -->
  <param name="robot_description" command="$(find xacro)/xacro
    '$(find gazebo_ros_tts)/urdf/demo_robot.urdf.xacro'
    tts_engine:=$(arg tts_engine)
    topic:=$(arg topic)
    voice:=$(arg voice)
    rate:=$(arg rate)"/>

  <!-- ── Spawn robot in Gazebo ─────────────────── -->
  <node name="spawn_robot"
        pkg="gazebo_ros"
        type="spawn_model"
        args="-param robot_description
              -urdf
              -model tts_demo_robot
              -x 0 -y 0 -z 0.5"
        output="screen"/>

  <!-- ── Startup speech (2 sec baad) ─────────── -->
  <node name="startup_speech"
        pkg="rostopic"
        type="rostopic"
        args="pub -1 $(arg topic)
              std_msgs/String
              'data: Hello! I am a talking robot in Gazebo!'"
        launch-prefix="bash -c 'sleep 3; $0 $@'"/>

</launch>
